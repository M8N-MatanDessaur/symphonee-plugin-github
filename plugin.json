{
  "id": "github",
  "name": "GitHub",
  "version": "0.6.0",
  "sdkVersion": 2,
  "description": "GitHub integration: repositories, pull requests, reviews, cloning, git log",
  "icon": "github",
  "tint": "110, 125, 170",
  "instructions": "instructions.md",
  "aiKeywords": [
    "github",
    "git hub",
    "gh",
    "pull request",
    "pr",
    "code review",
    "clone repo",
    "clone from github",
    "github repo",
    "github repos"
  ],
  "activationConditions": {
    "configKeys": [
      "GitHubPAT"
    ]
  },
  "settings": [],
  "contributions": {
    "routes": "routes.js",
    "configKeys": [
      "GitHubPAT"
    ],
    "sensitiveKeys": [
      "GitHubPAT"
    ],
    "nativeSettings": {
      "targetId": "settingsSection-github"
    },
    "legacyNativeTabs": [
      {
        "tabBtnId": "prsTabBtn",
        "panelId": "panel-prs",
        "openable": true
      }
    ],
    "rightTabs": [
      {
        "id": "gitlog",
        "label": "Git Log",
        "icon": "git-commit",
        "html": "ui/gitlog.html"
      }
    ],
    "repoSources": [
      {
        "id": "github",
        "label": "Clone from GitHub",
        "icon": "github",
        "listRoute": "/api/github/user-repos",
        "cloneRoute": "/api/github/clone"
      }
    ],
    "commitLinkers": [
      {
        "id": "github-pr-ref",
        "pattern": "(?:^|\\s)#(\\d+)\\b",
        "urlTemplate": "https://github.com/{owner}/{repo}/pull/{1}",
        "note": "Matches '#123' in commit messages and resolves via parseGitHubRemote"
      }
    ],
    "prProvider": {
      "id": "github",
      "label": "GitHub",
      "listRoute": "/api/github/pulls",
      "detailRoute": "/api/github/pulls/detail",
      "filesRoute": "/api/github/pulls/files",
      "commentsRoute": "/api/github/pulls/comments",
      "timelineRoute": "/api/github/pulls/timeline",
      "commentRoute": "/api/github/pulls/comment",
      "reviewRoute": "/api/github/pulls/review",
      "createRoute": "/api/pull-request"
    }
  }
}
